# ────────────────────────────────────────────────────────────
# Kritika Mandale Portfolio — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ────────────────────────────────────────────────────────────

# ── Resend (Email delivery) ──────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address shown on outbound email.
# Must be a verified domain in your Resend account.
# Use onboarding@resend.dev for testing only.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Your personal inbox that receives portfolio inquiries.
RESEND_TO_EMAIL=kritikamandale@gmail.com

# ── hCaptcha ─────────────────────────────────────────────────
# Register at https://dashboard.hcaptcha.com/
# Secret key — server-side only, never expose to the client.
HCAPTCHA_SECRET=your_hcaptcha_secret_key_here

# Site key — safe to expose; used by the React widget.
NEXT_PUBLIC_HCAPTCHA_SITEKEY=your_hcaptcha_site_key_here

# ── Dev overrides ─────────────────────────────────────────────
# Set to "true" to bypass hCaptcha verification in local dev.
# Must be unset or "false" in production.
SKIP_HCAPTCHA=false

# Base URL for the API — leave empty when running on Vercel
# (the serverless function lives at /api/contact automatically).
NEXT_PUBLIC_API_URL=
